{
  "name": "@max-ts/svelte",
  "version": "1.12.0",
  "type": "module",
  "description": "Svelte component library.",
  "author": "Tsepelev Maksim",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/components/index.d.ts",
      "svelte": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    },
    "./package.json": "./package.json",
    "./theme": {
      "types": "./dist/theme.d.ts",
      "default": "./dist/theme.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "default": "./dist/utils.js"
    },
    "./styles.css": "./dist/assets/styles.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "play": "vite",
    "test": "vitest",
    "lint:types": "svelte-check --tsconfig ./tsconfig.json",
    "lint:code": "biome check --write",
    "lint": "pnpm run lint:types && pnpm run lint:code",
    "release": "bumpp && pnpm publish",
    "storybook": "storybook dev -p 6006",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@internationalized/date": "^3.10.1",
    "svelte": "^5.53.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@changesets/cli": "^2.31.0",
    "@chromatic-com/storybook": "^5.1.2",
    "@internationalized/date": "^3.12.1",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/sveltekit": "^10.3.6",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25.6.0",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/rollup-plugin": "^1.5.3",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitest/browser-playwright": "^4.1.5",
    "bumpp": "^11.0.1",
    "rollup-plugin-svelte": "^7.2.3",
    "storybook": "^10.3.6",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.7",
    "svelte2tsx": "^0.7.54",
    "tsdown": "0.21.10",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5",
    "vitest-browser-svelte": "^2.1.1"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@lucide/svelte": "^1.14.0",
    "bits-ui": "^2.18.1"
  }
}
