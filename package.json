{
  "name": "@max-ts/svelte",
  "version": "1.14.3",
  "type": "module",
  "description": "Svelte component library.",
  "author": "Tsepelev Maksim",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/components/index.d.ts",
      "svelte": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    },
    "./package.json": "./package.json",
    "./theme": {
      "types": "./dist/theme.d.ts",
      "default": "./dist/theme.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "default": "./dist/utils.js"
    },
    "./styles.css": "./dist/assets/styles.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "play": "vite",
    "test": "vitest",
    "lint:types": "svelte-check --tsconfig ./tsconfig.json",
    "lint:code": "biome check --write",
    "lint": "pnpm run lint:types && pnpm run lint:code",
    "release": "bumpp && pnpm publish",
    "storybook": "storybook dev -p 6006",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@internationalized/date": "^3.10.1",
    "svelte": "^5.53.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@changesets/cli": "^2.31.1",
    "@chromatic-com/storybook": "^5.2.1",
    "@internationalized/date": "^3.12.2",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-docs": "^10.5.2",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-vitest": "^10.5.2",
    "@storybook/sveltekit": "^10.5.2",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tsconfig/svelte": "^5.0.8",
    "@tsdown/css": "^0.22.12",
    "@types/node": "^26.1.1",
    "@vanilla-extract/css": "^1.21.1",
    "@vanilla-extract/rollup-plugin": "^1.5.4",
    "@vanilla-extract/vite-plugin": "^5.2.5",
    "@vitest/browser-playwright": "^4.1.10",
    "bumpp": "^11.1.0",
    "rollup-plugin-svelte": "^7.2.3",
    "storybook": "^10.5.2",
    "svelte": "^5.56.6",
    "svelte-check": "^4.7.3",
    "svelte2tsx": "^0.7.58",
    "tsdown": "0.22.12",
    "typescript": "^6",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vitest-browser-svelte": "^3.0.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.8.0",
    "@lucide/svelte": "^1.25.0",
    "bits-ui": "^2.18.1"
  },
  "packageManager": "pnpm@11.15.1"
}
